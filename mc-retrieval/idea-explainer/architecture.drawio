        <mxCell id="strat_1" value="💡 &lt;b&gt;Strategy 1: Name Vocab&lt;/b&gt;&lt;br/&gt;&lt;font size=&quot;11&quot;&gt;Build block name mapping&lt;br/&gt;(254 unique non-air names → [0..255])&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAF5FF;strokeColor=#A855F7;strokeWidth=2;fontColor=#5B21B6;fontFamily=Helvetica;align=center;fontSize=12;" vertex="1" parent="1">
