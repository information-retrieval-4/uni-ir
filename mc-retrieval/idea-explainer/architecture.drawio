        <mxCell id="strat_2" value="💡 &lt;b&gt;Strategy 2: Semantic Init&lt;/b&gt;&lt;br/&gt;&lt;font size=&quot;11&quot;&gt;Pre-compute block name embeddings&lt;br/&gt;using SentenceTransformer&lt;br/&gt;• MD5 Hash Cache (caching to disk)&lt;br/&gt;• Project text_emb (384) → block_emb (64)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAF5FF;strokeColor=#A855F7;strokeWidth=2;fontColor=#5B21B6;fontFamily=Helvetica;align=center;fontSize=12;" vertex="1" parent="1">
