        <mxCell id="strat_3" value="💡 &lt;b&gt;Strategy 3: Material Context&lt;/b&gt;&lt;br/&gt;&lt;font size=&quot;11&quot;&gt;Extract top-K dominant block names&lt;br/&gt;and append to text prompt&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAF5FF;strokeColor=#A855F7;strokeWidth=2;fontColor=#5B21B6;fontFamily=Helvetica;align=center;fontSize=12;" vertex="1" parent="1">
